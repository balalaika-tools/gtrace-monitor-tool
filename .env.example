# AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# CloudWatch
LOG_GROUP_NAME=/your/cloudwatch/log-group-name
LOG_FILTER_PATTERN={ $.level = "TRACE" }
LOG_LEVEL=INFO
MAX_LOG_EVENTS=50000
SPAN_CONTENT_MAX_CHARS=900

# LLM pricing (USD per million tokens)
PRICE_INPUT=1.00
PRICE_OUTPUT=5.00
PRICE_CACHE_CREATION=1.25
PRICE_CACHE_READ=0.10

# S3
S3_BUCKET=ai-exception-poc-data
S3_CONFIG_PREFIX=config
S3_REPORTS_PREFIX=reports
